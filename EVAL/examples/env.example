# Optional virtual environment.
# VENV_PATH=/path/to/venv

# Models.
MODEL_PATH=/path/to/retriever_or_sql_model
SQL_MODEL=/path/to/sql_generator_model
BASE_MODEL_PATH=/path/to/base_model

# Greedy decoding defaults.
NUM_SAMPLES=1
TEMPERATURE=0.0

# BIRD paths.
BIRD_DEV_DATA=/path/to/bird/dev.json
BIRD_TABLES=/path/to/bird/dev_tables.json
BIRD_DB_PATH=/path/to/bird/dev_databases
BIRD_DB_CONTENT_INDEX_PATH=/path/to/bird/db_contents_index

# Spider paths.
SPIDER_DATA_DIR=/path/to/spider_data
SPIDER_DEV_DATA=/path/to/spider_data/dev.json
SPIDER_TABLES=/path/to/spider_data/tables.json
SPIDER_DB_PATH=/path/to/spider_data/database
SPIDER_DEV_GOLD=/path/to/spider_data/dev_gold.sql

# Spider robustness paths.
SPIDER_SOURCE=/path/to/original/spider_data
DATA_DIR=/path/to/omnisql_eval/data
TEST_SUITE_DB_PATH=/path/to/test_suite_database
